# CI / local: same glibc base as prod; dev deps for pytest.
FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY app ./app
COPY tests ./tests
COPY scripts ./scripts

RUN pip install --upgrade pip \
    && pip install -e ".[dev]"

# Offline suite only (live Leboncoin test is opt-in on the host).
CMD ["pytest", "-q", "--ignore=tests/test_real_leboncoin_optional.py"]
